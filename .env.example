# Google Cloud（RIZAP側の既存プロジェクト rizap-marketing）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Gemini(Vertex AI)の利用リージョン
GOOGLE_CLOUD_LOCATION=us-central1

# 被験者コンディションチェック スプレッドシートの親フォルダ（Google Drive フォルダID）
# 既定値はコードに埋め込み済み（本番フォルダ）。別環境で試す場合のみ上書きする。
COND_FOLDER_ID=1O7oYAdZ6opu_P9tZ-_0idO__E_WXKcGG

# Drive/Sheets/Vertex AIの認証は soxai-ring-runner サービスアカウント（ADC）を使う。
# ローカルではSAキーJSONのパスを指定する（本番はSecret Managerから自動マウント）。
# GOOGLE_APPLICATION_CREDENTIALS=credentials/sa-key.json
# OAuthトークンで試す場合のみ（フォールバック。scripts/generate_oauth_token.py で生成）
# GOOGLE_OAUTH_TOKEN_FILE=credentials/oauth-token.json

# Gemini（Vertex AI経由。APIキー管理は不要）
GEMINI_MODEL=gemini-2.5-flash
COMMENT_MIN_LEN=40
COMMENT_MAX_LEN=60

# フラグ検知（本人の過去データからのSD逸脱度）
SD_THRESHOLD=2.0
HISTORY_DAYS=30

# true にすると Sheets への書き込みをスキップ（動作確認用）
DRY_RUN=false
