# Google Cloud（RIZAP側の新規プロジェクト）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Gemini(Vertex AI)の利用リージョン
GOOGLE_CLOUD_LOCATION=us-central1

# 被験者コンディションチェック スプレッドシートの親フォルダ（Google Drive フォルダID）
COND_FOLDER_ID=your-drive-folder-id

# Drive/Sheetsへのアクセスは、RIZAP側の対象Googleアカウントで1回だけOAuth認可した
# トークンファイルを使う（scripts/generate_oauth_token.py で生成。サービスアカウントへの
# フォルダ共有は不要）。ファイルが無い場合はADC（GOOGLE_APPLICATION_CREDENTIALS等）にフォールバックする。
GOOGLE_OAUTH_TOKEN_FILE=credentials/oauth-token.json

# Gemini（Vertex AI経由。APIキー管理は不要）
GEMINI_MODEL=gemini-2.5-flash
COMMENT_MIN_LEN=40
COMMENT_MAX_LEN=60

# フラグ検知（本人の過去データからのSD逸脱度）
SD_THRESHOLD=2.0
HISTORY_DAYS=30

# true にすると Sheets への書き込みをスキップ（動作確認用）
DRY_RUN=false
